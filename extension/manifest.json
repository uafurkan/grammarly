{
  "manifest_version": 3,
  "name": "Pluma — Free Writing Assistant",
  "version": "1.0.0",
  "description": "Free, private grammar, spelling & clarity checks in any text box on the web. Your text stays on your device.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Pluma",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
